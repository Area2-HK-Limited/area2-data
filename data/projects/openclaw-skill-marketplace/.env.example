# ============================================================
# .env.example — OCM Private Skill Registry
# Copy to .env and fill in your values before deploying.
# ============================================================

# ── API Server ──────────────────────────────────────────────

# Port the API listens on (host-side bind)
API_PORT=3721

# Bind address: 127.0.0.1 = localhost only (safest for internal use)
# Set to 0.0.0.0 ONLY if behind a firewall / reverse proxy
API_HOST=127.0.0.1

# Max bundle size for skill uploads (MB)
MAX_BUNDLE_SIZE_MB=50

# ── PostgreSQL ───────────────────────────────────────────────

POSTGRES_USER=ocm
# REQUIRED — set a strong password
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=ocm

# External port for direct psql access (host only)
POSTGRES_EXTERNAL_PORT=5439
POSTGRES_HOST=127.0.0.1

# ── MinIO Object Storage ─────────────────────────────────────

# REQUIRED — set strong credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# Bucket name for skill bundles
MINIO_BUCKET=ocm-skills

# Ports for MinIO API and Console UI (host-side)
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_HOST=127.0.0.1

# ── Seed (first-time setup) ──────────────────────────────────

# Name and email for the initial owner account (used by db:seed)
SEED_OWNER_NAME=Eric
SEED_OWNER_EMAIL=admin@internal

# ── Notes ───────────────────────────────────────────────────
# All services bind to 127.0.0.1 by default.
# For same-host Docker access from other containers, use:
#   http://host.docker.internal:3721   (if host networking available)
#   http://172.17.0.1:3721             (Docker bridge default gateway)
# Or attach both compose projects to a shared Docker network.
